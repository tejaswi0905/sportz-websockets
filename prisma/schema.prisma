generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum MatchStatus {
  scheduled
  live
  finished
}

model Match {
  id        Int         @id @default(autoincrement())
  sport     String
  homeTeam  String
  awayTeam  String
  status    MatchStatus @default(scheduled)

  startTime DateTime?
  endTime   DateTime?

  homeScore Int @default(0)
  awayScore Int @default(0)

  createdAt DateTime @default(now())

  commentary Commentary[]
}

model Commentary {
  id       Int @id @default(autoincrement())

  matchId  Int
  match    Match @relation(fields: [matchId], references: [id])

  minute    Int?
  sequence  Int?
  period    String?
  eventType String?
  actor     String?
  team      String?

  message  String
  metadata Json?

  tags String[]

  createdAt DateTime @default(now())

  @@index([matchId])
}